---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Ranchos del Sol – Exclusive beach stays, premium car rentals, and private boat tours on the stunning coast of El Salvador.' } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/stays', label: 'Stays' },
  { href: '/cars', label: 'Car Rentals' },
  { href: '/boat-tours', label: 'Boat Tours' },
  { href: '/contact', label: 'Contact' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

</head>
<body class="font-sans bg-white text-ocean-dark antialiased">
  <!-- Navigation -->
  <header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="main-header">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex items-center justify-between h-20">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 group">
          <div class="w-10 h-10 rounded-xl bg-white/20 backdrop-blur-sm flex items-center justify-center group-hover:bg-white/30 transition-all border border-white/30">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <div>
            <span class="font-display font-bold text-lg text-white leading-tight block">Ranchos del Sol</span>
            <span class="text-white/70 text-xs">Costa del Sol, El Salvador</span>
          </div>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden md:flex items-center gap-1">
          {navLinks.map(link => (
            <a
              href={link.href}
              class={`px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 ${
                currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                  ? 'bg-white/25 text-white backdrop-blur-sm font-semibold'
                  : 'text-white/85 hover:text-white hover:bg-white/20 hover:backdrop-blur-sm'
              }`}
            >
              {link.label}
            </a>
          ))}
        </nav>

        <!-- CTA + Mobile Toggle -->
        <div class="flex items-center gap-3">
          <a href="/cars" class="hidden sm:inline-flex btn-nav-cta">
            Book a Car
          </a>
          <button id="mobile-menu-btn" class="md:hidden w-10 h-10 rounded-xl bg-white/15 backdrop-blur-sm flex items-center justify-center text-white hover:bg-white/25 transition-all border border-white/20">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" id="menu-icon">
              <path d="M3 12h18M3 6h18M3 18h18"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-ocean-dark/95 backdrop-blur-md border-t border-white/10">
      <div class="px-4 py-4 space-y-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="block px-4 py-3 rounded-xl text-white/85 hover:text-white hover:bg-white/10 text-sm font-medium transition-all"
          >
            {link.label}
          </a>
        ))}
        <a href="/cars" class="block px-4 py-3 rounded-xl bg-coral text-white text-sm font-semibold text-center mt-2">
          Book a Car
        </a>
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-ocean-dark text-white">
    <div class="max-w-7xl mx-auto px-4 py-16">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
        <!-- Brand -->
        <div class="md:col-span-2">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-turquoise" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <div>
              <p class="font-display font-bold text-lg">Ranchos del Sol</p>
              <p class="text-white/50 text-xs">Costa del Sol, El Salvador</p>
            </div>
          </div>
          <p class="text-white/70 text-sm leading-relaxed max-w-sm">
            Your gateway to the best of El Salvador's Pacific coast. Exclusive beach stays, premium car rentals, and unforgettable boat tours.
          </p>
          <div class="flex gap-3 mt-6">
            <a href="https://facebook.com" target="_blank" rel="noopener" class="w-9 h-9 bg-white/10 rounded-lg flex items-center justify-center hover:bg-white/20 transition-all text-white/70 hover:text-white">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
            <a href="https://instagram.com" target="_blank" rel="noopener" class="w-9 h-9 bg-white/10 rounded-lg flex items-center justify-center hover:bg-white/20 transition-all text-white/70 hover:text-white">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
            <a href="https://wa.me/50300000000" target="_blank" rel="noopener" class="w-9 h-9 bg-white/10 rounded-lg flex items-center justify-center hover:bg-white/20 transition-all text-white/70 hover:text-white">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            </a>
          </div>
        </div>

        <!-- Quick Links -->
        <div>
          <h4 class="font-display font-semibold text-sm uppercase tracking-widest text-white/50 mb-4">Explore</h4>
          <ul class="space-y-2.5">
            {navLinks.map(link => (
              <li><a href={link.href} class="text-white/70 hover:text-white text-sm transition-colors">{link.label}</a></li>
            ))}
          </ul>
        </div>

        <!-- Contact -->
        <div>
          <h4 class="font-display font-semibold text-sm uppercase tracking-widest text-white/50 mb-4">Contact</h4>
          <ul class="space-y-3 text-sm">
            <li class="flex items-start gap-2 text-white/70">
              <svg class="w-4 h-4 text-turquoise mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Costa del Sol, La Paz, El Salvador
            </li>
            <li>
              <a href="tel:+50300000000" class="flex items-center gap-2 text-white/70 hover:text-white transition-colors">
                <svg class="w-4 h-4 text-turquoise shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l.94-.94a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                +503 0000-0000
              </a>
            </li>
            <li>
              <a href="mailto:info@ranchosdelsol.com" class="flex items-center gap-2 text-white/70 hover:text-white transition-colors">
                <svg class="w-4 h-4 text-turquoise shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                info@ranchosdelsol.com
              </a>
            </li>
          </ul>
        </div>
      </div>

      <div class="border-t border-white/10 mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-white/50 text-xs">
        <p>© {new Date().getFullYear()} Ranchos del Sol. All rights reserved.</p>
        <div class="flex gap-4">
          <a href="/admin" class="hover:text-white/80 transition-colors">Admin</a>
          <span>·</span>
          <a href="https://ranchosdelsol.com" class="hover:text-white/80 transition-colors">ranchosdelsol.com</a>
        </div>
      </div>
    </div>
  </footer>

  <script>
    // Sticky nav scroll effect
    const header = document.getElementById('main-header');
    let ticking = false;
    const updateHeader = () => {
      if (window.scrollY > 50) {
        header?.classList.add('bg-ocean-dark/95', 'backdrop-blur-md', 'shadow-lg');
        header?.classList.remove('bg-transparent');
      } else {
        header?.classList.remove('bg-ocean-dark/95', 'backdrop-blur-md', 'shadow-lg');
      }
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateHeader);
        ticking = true;
      }
    }, { passive: true });
    updateHeader();

    // Smooth scroll for all anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', (e) => {
        const href = anchor.getAttribute('href');
        if (!href) return;
        const target = document.querySelector(href);
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    // Mobile menu toggle
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    mobileBtn?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('hidden');
    });
  </script>
</body>
</html>
