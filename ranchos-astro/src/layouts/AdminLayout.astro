---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

</head>
<body class="bg-gray-50 font-sans">
  <div class="flex h-screen overflow-hidden">
    <!-- Sidebar -->
    <aside class="w-64 bg-ocean-dark text-white flex flex-col shrink-0 overflow-y-auto" id="sidebar">
      <!-- Logo -->
      <div class="p-6 border-b border-white/10">
        <a href="/" class="flex items-center gap-3">
          <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-turquoise" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <div>
            <p class="font-display font-bold text-sm leading-tight">Ranchos del Sol</p>
            <p class="text-white/50 text-xs">Admin Panel</p>
          </div>
        </a>
      </div>

      <!-- Nav -->
      <nav class="flex-1 p-4 space-y-1">
        {[
          { href: '/admin/dashboard', label: 'Dashboard', icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>` },
          { href: '/admin/cars', label: 'Manage Fleet', icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>` },
          { href: '/admin/cars/new', label: 'Add New Car', icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>` },
          { href: '/admin/reservations', label: 'Reservations', icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>` },
        ].map(item => (
          <a
            href={item.href}
            class={`flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-white/10 ${Astro.url.pathname === item.href || Astro.url.pathname.startsWith(item.href + '/') ? 'bg-white/15 text-white' : 'text-white/70 hover:text-white'}`}
          >
            <span set:html={item.icon} />
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Footer -->
      <div class="p-4 border-t border-white/10 space-y-2">
        <a href="/" target="_blank" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm text-white/60 hover:text-white hover:bg-white/10 transition-all">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          View Website
        </a>
        <button id="logout-btn" class="w-full flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm text-white/60 hover:text-red-300 hover:bg-red-500/10 transition-all">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          Sign Out
        </button>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto">
      <!-- Top Bar -->
      <header class="bg-white border-b border-sand px-6 py-4 flex items-center justify-between sticky top-0 z-10">
        <h2 class="font-semibold text-ocean-dark">{title.replace(' – Admin', '')}</h2>
        <div class="flex items-center gap-3">
          <span class="text-xs text-gray-beach">Admin</span>
          <div class="w-8 h-8 bg-ocean rounded-full flex items-center justify-center text-white text-sm font-bold">A</div>
        </div>
      </header>

      <div class="p-6 md:p-8">
        <slot />
      </div>
    </main>
  </div>

  <script>
    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await fetch('/api/admin/login', { method: 'DELETE' });
      window.location.href = '/admin';
    });
  </script>
</body>
</html>
