---
import Layout from '../../layouts/Layout.astro';
import { getCarWithPhotos } from '../../lib/queries';
import ReservationForm from '../../components/ReservationForm';

const { id } = Astro.params;
let car: any = null;
try {
  car = await getCarWithPhotos(Number(id));
} catch (e) {}

if (!car) {
  return Astro.redirect('/cars');
}

const features = car.features ? JSON.parse(car.features) : [];
---

<Layout title={`${car.year} ${car.make} ${car.model} – Ranchos del Sol`}>
  <!-- Breadcrumb -->
  <div class="pt-28 pb-4 px-4 bg-white border-b border-sand">
    <div class="max-w-7xl mx-auto">
      <nav class="flex items-center gap-2 text-sm text-gray-beach">
        <a href="/" class="hover:text-ocean transition-colors">Home</a>
        <span>/</span>
        <a href="/cars" class="hover:text-ocean transition-colors">Car Rentals</a>
        <span>/</span>
        <span class="text-ocean-dark font-medium">{car.year} {car.make} {car.model}</span>
      </nav>
    </div>
  </div>

  <section class="py-12 px-4 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Photo Gallery -->
        <div>
          <!-- Main Photo -->
          <div class="relative rounded-2xl overflow-hidden bg-sand h-80 md:h-96 mb-4" id="main-photo-container">
            {car.photos && car.photos.length > 0 ? (
              <img
                id="main-photo"
                src={car.photos[0].url}
                alt={`${car.year} ${car.make} ${car.model}`}
                class="w-full h-full object-cover"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-ocean-light to-turquoise-light">
                <svg class="w-32 h-32 text-ocean/20" fill="none" stroke="currentColor" stroke-width="0.8" viewBox="0 0 24 24">
                  <rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                </svg>
              </div>
            )}
            <div class="absolute top-4 left-4">
              <span class={car.available ? 'badge-available' : 'badge-unavailable'}>
                {car.available ? '✓ Available' : 'Currently Unavailable'}
              </span>
            </div>
          </div>

          <!-- Thumbnail Strip -->
          {car.photos && car.photos.length > 1 && (
            <div class="flex gap-3 overflow-x-auto pb-2">
              {car.photos.map((photo: any, i: number) => (
                <button
                  class="thumb-btn shrink-0 w-20 h-16 rounded-xl overflow-hidden border-2 border-transparent hover:border-ocean transition-all"
                  data-url={photo.url}
                  data-index={i}
                >
                  <img src={photo.url} alt={`Photo ${i + 1}`} class="w-full h-full object-cover"/>
                </button>
              ))}
            </div>
          )}
        </div>

        <!-- Car Info -->
        <div>
          <div class="flex items-start justify-between gap-4 mb-4">
            <div>
              <span class="bg-sand text-ocean-dark text-xs font-semibold px-3 py-1 rounded-full capitalize">{car.category}</span>
              <h1 class="font-display text-3xl md:text-4xl font-bold text-ocean-dark mt-3">
                {car.year} {car.make} {car.model}
              </h1>
            </div>
            <div class="text-right shrink-0">
              <div class="text-4xl font-bold text-coral">${Number(car.daily_rate).toFixed(0)}</div>
              <div class="text-gray-beach text-sm">per day</div>
            </div>
          </div>

          {car.description && (
            <p class="text-gray-beach leading-relaxed mb-6">{car.description}</p>
          )}

          <!-- Specs Grid -->
          <div class="grid grid-cols-2 gap-4 mb-6">
            {[
              { label: 'Seats', value: `${car.seats} passengers`, icon: '👥' },
              { label: 'Transmission', value: car.transmission, icon: '⚙️' },
              { label: 'Fuel Type', value: car.fuel_type, icon: '⛽' },
              { label: 'Category', value: car.category, icon: '🚗' },
            ].map(spec => (
              <div class="bg-sand/50 rounded-xl p-4">
                <div class="text-xl mb-1">{spec.icon}</div>
                <div class="text-xs text-gray-beach">{spec.label}</div>
                <div class="font-semibold text-ocean-dark capitalize">{spec.value}</div>
              </div>
            ))}
          </div>

          <!-- Features -->
          {features.length > 0 && (
            <div class="mb-6">
              <h3 class="font-semibold text-ocean-dark mb-3">Features & Amenities</h3>
              <div class="flex flex-wrap gap-2">
                {features.map((f: string) => (
                  <span class="bg-turquoise-light text-ocean-dark text-sm px-3 py-1.5 rounded-full font-medium">✓ {f}</span>
                ))}
              </div>
            </div>
          )}

          <!-- Pricing Summary -->
          <div class="bg-sand/40 rounded-xl p-5 mb-6">
            <h3 class="font-semibold text-ocean-dark mb-3">Pricing</h3>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between"><span class="text-gray-beach">Daily Rate</span><span class="font-semibold">${Number(car.daily_rate).toFixed(2)}/day</span></div>
              <div class="flex justify-between"><span class="text-gray-beach">Security Deposit</span><span class="font-semibold">$150.00</span></div>
              <div class="flex justify-between"><span class="text-gray-beach">Insurance</span><span class="font-semibold text-palm">Included</span></div>
            </div>
          </div>

          {!car.available && (
            <div class="bg-coral-light border border-coral/30 rounded-xl p-4 mb-4 text-coral-dark text-sm">
              This vehicle is currently unavailable. Please check back later or <a href="/contact" class="underline font-semibold">contact us</a> for alternatives.
            </div>
          )}
        </div>
      </div>

      <!-- Reservation Form -->
      {car.available && (
        <div class="mt-16">
          <div class="max-w-2xl mx-auto">
            <div class="text-center mb-8">
              <h2 class="section-heading">Reserve This Vehicle</h2>
              <p class="text-gray-beach mt-2">Fill in your details to book the {car.year} {car.make} {car.model}.</p>
            </div>
            <ReservationForm
              client:load
              carId={car.id}
              carName={`${car.year} ${car.make} ${car.model}`}
              dailyRate={Number(car.daily_rate)}
            />
          </div>
        </div>
      )}
    </div>
  </section>
</Layout>

<script>
  const thumbBtns = document.querySelectorAll('.thumb-btn');
  const mainPhoto = document.getElementById('main-photo') as HTMLImageElement;

  thumbBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const url = btn.getAttribute('data-url');
      if (mainPhoto && url) mainPhoto.src = url;
      thumbBtns.forEach(b => b.classList.remove('border-ocean'));
      btn.classList.add('border-ocean');
    });
  });
</script>
