---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { checkAdminAuth } from '../../../lib/auth';
import CarForm from '../../../components/admin/CarForm';

if (!checkAdminAuth(Astro.request)) {
  return Astro.redirect('/admin');
}
---

<AdminLayout title="Add New Car – Admin">
  <div class="max-w-3xl">
    <div class="mb-6">
      <a href="/admin/cars" class="text-gray-beach hover:text-ocean text-sm flex items-center gap-1 mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Back to Fleet
      </a>
      <h1 class="font-display text-2xl font-bold text-ocean-dark">Add New Vehicle</h1>
      <p class="text-gray-beach text-sm mt-1">Fill in the details below. You'll be able to add photos on the next step.</p>
    </div>

    <CarForm client:load />
  </div>
</AdminLayout>
