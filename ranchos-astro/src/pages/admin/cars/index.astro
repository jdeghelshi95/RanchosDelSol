---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { checkAdminAuth } from '../../../lib/auth';
import { getCarsWithPrimaryPhoto } from '../../../lib/queries';

if (!checkAdminAuth(Astro.request)) {
  return Astro.redirect('/admin');
}

let cars: any[] = [];
try {
  cars = await getCarsWithPrimaryPhoto();
} catch (e) {}
---

<AdminLayout title="Manage Fleet – Admin">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="font-display text-2xl font-bold text-ocean-dark">Manage Fleet</h1>
        <p class="text-gray-beach text-sm mt-1">{cars.length} vehicle{cars.length !== 1 ? 's' : ''} in your fleet</p>
      </div>
      <a href="/admin/cars/new" class="btn-primary">+ Add New Car</a>
    </div>

    {cars.length > 0 ? (
      <div class="bg-white rounded-2xl shadow-sm border border-sand overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="bg-sand/50 text-left">
                <th class="px-6 py-3 text-xs font-semibold text-gray-beach uppercase tracking-wider">Vehicle</th>
                <th class="px-6 py-3 text-xs font-semibold text-gray-beach uppercase tracking-wider">Category</th>
                <th class="px-6 py-3 text-xs font-semibold text-gray-beach uppercase tracking-wider">Daily Rate</th>
                <th class="px-6 py-3 text-xs font-semibold text-gray-beach uppercase tracking-wider">Specs</th>
                <th class="px-6 py-3 text-xs font-semibold text-gray-beach uppercase tracking-wider">Photos</th>
                <th class="px-6 py-3 text-xs font-semibold text-gray-beach uppercase tracking-wider">Status</th>
                <th class="px-6 py-3 text-xs font-semibold text-gray-beach uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-sand">
              {cars.map((car: any) => (
                <tr class="hover:bg-sand/20 transition-colors">
                  <td class="px-6 py-4">
                    <div class="flex items-center gap-3">
                      <div class="w-16 h-12 rounded-lg overflow-hidden bg-sand shrink-0">
                        {car.primaryPhoto ? (
                          <img src={car.primaryPhoto} alt={car.make} class="w-full h-full object-cover"/>
                        ) : (
                          <div class="w-full h-full flex items-center justify-center text-sand-dark">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                          </div>
                        )}
                      </div>
                      <div>
                        <p class="font-semibold text-ocean-dark text-sm">{car.year} {car.make} {car.model}</p>
                        <p class="text-xs text-gray-beach">ID #{car.id}</p>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4">
                    <span class="bg-sand text-ocean-dark text-xs font-semibold px-2.5 py-1 rounded-full capitalize">{car.category}</span>
                  </td>
                  <td class="px-6 py-4 font-bold text-coral">${Number(car.daily_rate).toFixed(2)}/day</td>
                  <td class="px-6 py-4 text-sm text-gray-beach">
                    <div>{car.seats} seats · {car.transmission}</div>
                    <div class="capitalize">{car.fuel_type}</div>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-beach">
                    {car.photos?.length || 0} photo{(car.photos?.length || 0) !== 1 ? 's' : ''}
                  </td>
                  <td class="px-6 py-4">
                    <span class={`inline-flex px-2.5 py-1 rounded-full text-xs font-semibold ${car.available ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`}>
                      {car.available ? '✓ Available' : '✗ Unavailable'}
                    </span>
                  </td>
                  <td class="px-6 py-4">
                    <div class="flex items-center gap-2">
                      <a href={`/admin/cars/${car.id}/edit`} class="text-ocean hover:text-ocean-dark text-sm font-medium hover:underline">Edit</a>
                      <span class="text-sand-dark">|</span>
                      <a href={`/admin/cars/${car.id}/photos`} class="text-turquoise hover:text-ocean text-sm font-medium hover:underline">Photos</a>
                      <span class="text-sand-dark">|</span>
                      <button
                        class="text-red-500 hover:text-red-700 text-sm font-medium hover:underline delete-car-btn"
                        data-id={car.id}
                        data-name={`${car.year} ${car.make} ${car.model}`}
                      >
                        Delete
                      </button>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    ) : (
      <div class="bg-white rounded-2xl shadow-sm border border-sand text-center py-16">
        <div class="text-5xl mb-4">🚗</div>
        <h3 class="font-display text-xl font-bold text-ocean-dark mb-2">No Vehicles Yet</h3>
        <p class="text-gray-beach mb-6">Add your first car to get started.</p>
        <a href="/admin/cars/new" class="btn-primary inline-flex">+ Add First Car</a>
      </div>
    )}
  </div>
</AdminLayout>

<script>
  document.querySelectorAll('.delete-car-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id');
      const name = btn.getAttribute('data-name');
      if (!confirm(`Delete ${name}? This will also delete all photos and cannot be undone.`)) return;

      try {
        const res = await fetch(`/api/cars/${id}`, { method: 'DELETE' });
        if (res.ok) {
          window.location.reload();
        } else {
          const data = await res.json();
          alert(data.error || 'Failed to delete car');
        }
      } catch {
        alert('Connection error');
      }
    });
  });
</script>
