---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us – Ranchos del Sol">
  <!-- Hero -->
  <section class="pt-32 pb-16 px-4 bg-gradient-to-br from-ocean-dark to-ocean text-white text-center">
    <div class="max-w-3xl mx-auto">
      <p class="text-turquoise font-semibold text-sm uppercase tracking-widest mb-3">Get in Touch</p>
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">Contact Us</h1>
      <p class="text-white/80 text-lg">We're here to help you plan the perfect Costa del Sol experience.</p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact Info -->
        <div>
          <h2 class="section-heading mb-8">Find Us</h2>

          <div class="space-y-6 mb-10">
            {[
              {
                icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
                title: 'Location',
                lines: ['Costa del Sol, La Paz', 'El Salvador, Central America'],
                color: 'coral',
              },
              {
                icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l.94-.94a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
                title: 'Phone & WhatsApp',
                lines: ['+503 0000-0000'],
                color: 'turquoise',
                link: 'tel:+50300000000',
              },
              {
                icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
                title: 'Email',
                lines: ['info@ranchosdelsol.com'],
                color: 'ocean',
                link: 'mailto:info@ranchosdelsol.com',
              },
              {
                icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>`,
                title: 'Hours',
                lines: ['Mon–Sun: 7:00 AM – 8:00 PM', 'Car pickup: 8:00 AM – 6:00 PM'],
                color: 'sunset',
              },
            ].map(item => (
              <div class="flex items-start gap-4">
                <div class={`w-12 h-12 rounded-xl bg-${item.color}/10 text-${item.color} flex items-center justify-center shrink-0`} set:html={item.icon}/>
                <div>
                  <h4 class="font-semibold text-ocean-dark">{item.title}</h4>
                  {item.lines.map(line => (
                    item.link
                      ? <a href={item.link} class="text-gray-beach hover:text-ocean transition-colors block">{line}</a>
                      : <p class="text-gray-beach">{line}</p>
                  ))}
                </div>
              </div>
            ))}
          </div>

          <!-- Directions -->
          <div class="bg-sand/50 rounded-2xl p-6">
            <h3 class="font-display font-semibold text-lg text-ocean-dark mb-3">Driving Directions</h3>
            <p class="text-gray-beach text-sm leading-relaxed mb-4">
              From San Salvador International Airport (SAL): Take the Litoral Highway (CA-2) heading west toward La Paz. Continue approximately 45 km along the coast. Ranchos del Sol is located on the main coastal road in Costa del Sol, La Paz.
            </p>
            <p class="text-gray-beach text-sm">
              <strong>Approximate drive time:</strong> 45–60 minutes from the airport.
            </p>
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <h2 class="section-heading mb-8">Send a Message</h2>
          <form id="contact-form" class="bg-white rounded-2xl shadow-md p-8 space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="label-beach">First Name *</label>
                <input type="text" name="firstName" required placeholder="John" class="input-beach"/>
              </div>
              <div>
                <label class="label-beach">Last Name *</label>
                <input type="text" name="lastName" required placeholder="Doe" class="input-beach"/>
              </div>
            </div>
            <div>
              <label class="label-beach">Email *</label>
              <input type="email" name="email" required placeholder="john@example.com" class="input-beach"/>
            </div>
            <div>
              <label class="label-beach">Phone</label>
              <input type="tel" name="phone" placeholder="+503 0000-0000" class="input-beach"/>
            </div>
            <div>
              <label class="label-beach">Subject *</label>
              <select name="subject" required class="input-beach">
                <option value="">Select a topic...</option>
                <option value="car-rental">Car Rental Inquiry</option>
                <option value="stays">Stays / Accommodation</option>
                <option value="boat-tours">Boat Tours</option>
                <option value="reservation">Existing Reservation</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label class="label-beach">Message *</label>
              <textarea name="message" required rows={5} placeholder="Tell us how we can help..." class="input-beach resize-none"></textarea>
            </div>
            <button type="submit" class="btn-primary w-full justify-center py-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
              Send Message
            </button>
            <div id="form-success" class="hidden text-center p-4 bg-green-50 border border-green-200 rounded-xl text-green-700 text-sm font-medium">
              ✓ Message sent! We'll get back to you within 24 hours.
            </div>
          </form>
        </div>
      </div>

      <!-- Map -->
      <div class="mt-16">
        <h2 class="section-heading mb-6 text-center">Our Location</h2>
        <div class="rounded-2xl overflow-hidden shadow-xl h-96">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d30702.4!2d-89.0!3d13.2!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8f63b5c0c0c0c0c1%3A0x0!2sCosta+del+Sol%2C+La+Paz%2C+El+Salvador!5e0!3m2!1sen!2sus!4v1234567890"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ranchos del Sol Location"
          ></iframe>
        </div>
        <p class="text-center text-gray-beach text-sm mt-4">
          📍 Costa del Sol, La Paz, El Salvador — 
          <a href="https://maps.google.com/?q=Costa+del+Sol,+La+Paz,+El+Salvador" target="_blank" rel="noopener" class="text-ocean hover:underline">Open in Google Maps</a>
        </p>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending...';

    // Simulate send (replace with actual API call)
    await new Promise(r => setTimeout(r, 1000));

    successMsg?.classList.remove('hidden');
    form.reset();
    btn.disabled = false;
    btn.innerHTML = `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Send Message`;
  });
</script>
