---
import Layout from '../layouts/Layout.astro';
import { getCarsWithPrimaryPhoto } from '../lib/queries';

let featuredCars: any[] = [];
try {
  featuredCars = getCarsWithPrimaryPhoto(true).slice(0, 3);
} catch (e) {
  // DB not yet seeded
}
---

<Layout title="Ranchos del Sol – Beach Stays, Car Rentals & Boat Tours in El Salvador">
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1920&q=80"
        alt="Costa del Sol beach"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-ocean-dark/60 via-ocean/40 to-ocean-dark/70"></div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 z-10">
      <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z" fill="oklch(0.98 0.01 200)" opacity="1"/>
      </svg>
    </div>
    <div class="relative z-10 text-center text-white px-4 max-w-5xl mx-auto pt-20">
      <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm border border-white/25 rounded-full px-5 py-2 mb-8 text-sm font-medium">
        <span class="w-2 h-2 bg-turquoise rounded-full animate-pulse"></span>
        Costa del Sol, El Salvador
      </div>
      <h1 class="font-display text-5xl sm:text-6xl md:text-7xl font-bold mb-6 leading-tight">
        Your Paradise<br/><span class="text-turquoise">Awaits</span>
      </h1>
      <p class="text-xl md:text-2xl text-white/85 mb-10 max-w-2xl mx-auto leading-relaxed">
        Exclusive beach stays, premium car rentals, and private boat tours on the stunning coast of El Salvador.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/cars" class="btn-primary text-base px-8 py-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          Rent a Car
        </a>
        <a href="/stays" class="btn-outline-white text-base px-8 py-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          View Stays
        </a>
      </div>
      <div class="grid grid-cols-3 gap-6 mt-16 max-w-lg mx-auto">
        <div class="text-center"><div class="font-display text-3xl font-bold text-white">10+</div><div class="text-white/70 text-sm mt-1">Vehicles</div></div>
        <div class="text-center"><div class="font-display text-3xl font-bold text-white">4.9★</div><div class="text-white/70 text-sm mt-1">Rating</div></div>
        <div class="text-center"><div class="font-display text-3xl font-bold text-white">500+</div><div class="text-white/70 text-sm mt-1">Happy Guests</div></div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-24 px-4 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-coral font-semibold text-sm uppercase tracking-widest mb-3">What We Offer</p>
        <h2 class="section-heading">Everything for the Perfect Getaway</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <a href="/stays" class="card-beach group p-8 text-center block">
          <div class="w-16 h-16 rounded-2xl bg-ocean/10 text-ocean flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3 class="font-display text-xl font-bold text-ocean-dark mb-3">Beach Stays</h3>
          <p class="text-gray-beach text-sm leading-relaxed mb-4">Elegant Airbnb-style accommodations steps from the Pacific. Private beach access, pools, and stunning ocean views.</p>
          <span class="text-ocean font-semibold text-sm inline-flex items-center gap-1">Explore Stays <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/cars" class="card-beach group p-8 text-center block">
          <div class="w-16 h-16 rounded-2xl bg-coral/10 text-coral flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          </div>
          <h3 class="font-display text-xl font-bold text-ocean-dark mb-3">Car Rentals</h3>
          <p class="text-gray-beach text-sm leading-relaxed mb-4">Explore Costa del Sol and beyond with our premium fleet. SUVs, sedans, and trucks — all well-maintained and insured.</p>
          <span class="text-coral font-semibold text-sm inline-flex items-center gap-1">Browse Fleet <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </a>
        <a href="/boat-tours" class="card-beach group p-8 text-center block">
          <div class="w-16 h-16 rounded-2xl bg-turquoise/10 text-turquoise flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M2 20h20"/><path d="M5 20V10l7-7 7 7v10"/><path d="M9 20v-5h6v5"/></svg>
          </div>
          <h3 class="font-display text-xl font-bold text-ocean-dark mb-3">Boat Tours</h3>
          <p class="text-gray-beach text-sm leading-relaxed mb-4">Private tours along the coast, visits to Isla Tasajera, fishing excursions, and sunset cruises on the Pacific.</p>
          <span class="text-turquoise font-semibold text-sm inline-flex items-center gap-1">See Tours <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Cars -->
  <section class="py-24 px-4 bg-sand/40">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4">
        <div>
          <p class="text-coral font-semibold text-sm uppercase tracking-widest mb-3">Our Fleet</p>
          <h2 class="section-heading">Featured Vehicles</h2>
        </div>
        <a href="/cars" class="btn-secondary shrink-0">View All Cars <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
      </div>
      {featuredCars.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {featuredCars.map((car: any) => (
            <a href={`/cars/${car.id}`} class="card-beach group block">
              <div class="relative h-52 overflow-hidden bg-sand">
                {car.primaryPhoto ? (
                  <img src={car.primaryPhoto} alt={`${car.year} ${car.make} ${car.model}`} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"/>
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-ocean-light to-turquoise-light">
                    <svg class="w-20 h-20 text-ocean/30" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  </div>
                )}
                <div class="absolute top-3 right-3">
                  <span class={car.available ? 'badge-available' : 'badge-unavailable'}>{car.available ? '✓ Available' : 'Unavailable'}</span>
                </div>
                <div class="absolute top-3 left-3">
                  <span class="bg-white/90 backdrop-blur-sm text-ocean-dark text-xs font-semibold px-2.5 py-1 rounded-full capitalize">{car.category}</span>
                </div>
              </div>
              <div class="p-5">
                <h3 class="font-display font-bold text-lg text-ocean-dark">{car.year} {car.make} {car.model}</h3>
                <div class="flex items-center gap-4 mt-2 text-sm text-gray-beach">
                  <span>{car.seats} seats</span>
                  <span class="capitalize">{car.transmission}</span>
                  <span class="capitalize">{car.fuel_type}</span>
                </div>
                <div class="flex items-center justify-between mt-4 pt-4 border-t border-sand">
                  <div><span class="text-2xl font-bold text-coral">${Number(car.daily_rate).toFixed(0)}</span><span class="text-gray-beach text-sm">/day</span></div>
                  <span class="text-ocean font-semibold text-sm group-hover:underline">Book Now →</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-16 bg-white rounded-2xl">
          <p class="text-gray-beach text-lg mb-4">Our fleet is being updated. Check back soon!</p>
          <a href="/contact" class="btn-primary inline-flex">Contact Us</a>
        </div>
      )}
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-24 px-4 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-coral font-semibold text-sm uppercase tracking-widest mb-3">Why Ranchos del Sol</p>
          <h2 class="section-heading mb-6">The Best Way to Experience El Salvador</h2>
          <p class="text-gray-beach leading-relaxed mb-8">Nestled on the shores of Costa del Sol, Ranchos del Sol offers an unmatched combination of luxury, adventure, and authentic Salvadoran hospitality.</p>
          <div class="space-y-5">
            <div class="flex items-start gap-4"><div class="w-12 h-12 rounded-xl bg-sand flex items-center justify-center text-2xl shrink-0">🏖️</div><div><h4 class="font-semibold text-ocean-dark">Private Beach Access</h4><p class="text-gray-beach text-sm mt-0.5">Exclusive access to pristine Pacific beaches, away from the crowds.</p></div></div>
            <div class="flex items-start gap-4"><div class="w-12 h-12 rounded-xl bg-sand flex items-center justify-center text-2xl shrink-0">🚗</div><div><h4 class="font-semibold text-ocean-dark">Well-Maintained Fleet</h4><p class="text-gray-beach text-sm mt-0.5">All vehicles are regularly serviced, insured, and ready for any road.</p></div></div>
            <div class="flex items-start gap-4"><div class="w-12 h-12 rounded-xl bg-sand flex items-center justify-center text-2xl shrink-0">⭐</div><div><h4 class="font-semibold text-ocean-dark">5-Star Service</h4><p class="text-gray-beach text-sm mt-0.5">Our team is available 24/7 to ensure your stay is perfect.</p></div></div>
            <div class="flex items-start gap-4"><div class="w-12 h-12 rounded-xl bg-sand flex items-center justify-center text-2xl shrink-0">📍</div><div><h4 class="font-semibold text-ocean-dark">Prime Location</h4><p class="text-gray-beach text-sm mt-0.5">Minutes from the airport and centrally located along the coast.</p></div></div>
          </div>
        </div>
        <div class="relative">
          <img src="https://images.unsplash.com/photo-1559827260-dc66d52bef19?w=800&q=80" alt="Costa del Sol" class="rounded-2xl shadow-xl w-full object-cover h-[500px]"/>
          <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl shadow-xl p-5 max-w-xs">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 bg-turquoise/10 rounded-xl flex items-center justify-center text-2xl">🌊</div>
              <div><p class="font-bold text-ocean-dark">Isla Tasajera</p><p class="text-gray-beach text-xs">Private boat tours available</p></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-24 px-4 bg-gradient-to-br from-ocean-dark to-ocean">
    <div class="max-w-7xl mx-auto text-center">
      <p class="text-turquoise font-semibold text-sm uppercase tracking-widest mb-3">Guest Reviews</p>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-12">What Our Guests Say</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-8 text-left border border-white/15"><div class="flex gap-1 mb-4">★★★★★</div><p class="text-white/90 leading-relaxed mb-6 italic">"Absolutely stunning property! The car rental made it so easy to explore the coast. Will definitely be back."</p><div class="flex items-center gap-3"><div class="w-10 h-10 rounded-full bg-turquoise/30 flex items-center justify-center text-white font-bold">S</div><div><p class="text-white font-semibold text-sm">Sarah M.</p><p class="text-white/60 text-xs">United States</p></div></div></div>
        <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-8 text-left border border-white/15"><div class="flex gap-1 mb-4">★★★★★</div><p class="text-white/90 leading-relaxed mb-6 italic">"The boat tour to Isla Tasajera was the highlight of our trip. The staff went above and beyond."</p><div class="flex items-center gap-3"><div class="w-10 h-10 rounded-full bg-turquoise/30 flex items-center justify-center text-white font-bold">C</div><div><p class="text-white font-semibold text-sm">Carlos R.</p><p class="text-white/60 text-xs">Guatemala</p></div></div></div>
        <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-8 text-left border border-white/15"><div class="flex gap-1 mb-4">★★★★★</div><p class="text-white/90 leading-relaxed mb-6 italic">"Perfect beach getaway. The SUV we rented was in great condition and the pickup was seamless."</p><div class="flex items-center gap-3"><div class="w-10 h-10 rounded-full bg-turquoise/30 flex items-center justify-center text-white font-bold">E</div><div><p class="text-white font-semibold text-sm">Emma L.</p><p class="text-white/60 text-xs">Canada</p></div></div></div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-4 bg-sand/40">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="section-heading mb-4">Ready for Your Beach Adventure?</h2>
      <p class="text-gray-beach text-lg mb-10">Book your stay, reserve a car, or plan a boat tour today.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/cars" class="btn-primary text-base px-8 py-4">Reserve a Car</a>
        <a href="/contact" class="btn-secondary text-base px-8 py-4">Contact Us</a>
      </div>
    </div>
  </section>
</Layout>
